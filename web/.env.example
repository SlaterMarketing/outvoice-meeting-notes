# Copy to .env.local (see repo README)

DATABASE_URL=
AUTH_SECRET=

# Optional: email sign-in (Resend)
RESEND_API_KEY=
# Verified domain in Resend — we build: "Outvoice" <noreply@YOUR_DOMAIN>
EMAIL_FROM_DOMAIN=
# Optional (defaults: Outvoice / noreply)
# EMAIL_FROM_NAME=Outvoice
# EMAIL_FROM_LOCAL=noreply
# Optional: full From header — wins over EMAIL_FROM_DOMAIN if set
# EMAIL_FROM=Outvoice <hello@mail.example.com>

# TTS.ai — transcription (/v1/stt/) and notes (/v1/voice-chat/)
TTS_AI_API_KEY=

# Optional overrides
# TTS_AI_API_BASE=https://api.tts.ai/v1
# TTS_AI_STT_MODEL=faster-whisper
# TTS_AI_STT_LANGUAGE=auto
# TTS_AI_VOICE_CHAT_VOICE=af_bella

NEXT_PUBLIC_APP_URL=http://localhost:3000
